---
import { ViewTransitions } from 'astro:transitions';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import SakuraCanvas from '../components/SakuraCanvas.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import '../styles/global.css';

interface BackgroundAssets {
  default?: string;
  dark?: string;
  light?: string;
}

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  seoTitleKey?: string;
  seoDescriptionKey?: string;
  seoTitleFallback?: string;
  seoDescriptionFallback?: string;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleTags?: string[];
  backgroundAssets?: BackgroundAssets;
}

const {
  title = 'PhSeCl',
  description = 'PhSeCl.com personal website',
  lang = 'zh',
  seoTitleKey,
  seoDescriptionKey,
  seoTitleFallback,
  seoDescriptionFallback,
  ogType = 'website',
  articlePublishedTime,
  articleTags = [],
  backgroundAssets,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://phsecl.com');
const ogImageUrl = new URL('/media/site/branding/og-image.png', Astro.site ?? 'https://phsecl.com');
const finalTitle = title === 'PhSeCl' ? title : `${title} \u2014 PhSeCl`;
const hasBackgroundAssets = Boolean(
  backgroundAssets?.default || backgroundAssets?.dark || backgroundAssets?.light,
);
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ViewTransitions />
    <title
      data-seo-title-key={seoTitleKey}
      data-seo-title-fallback={seoTitleFallback ?? title}
    >
      {finalTitle}
    </title>
    <meta
      name="description"
      content={description}
      data-seo-description-key={seoDescriptionKey}
      data-seo-description-fallback={seoDescriptionFallback ?? description}
    />
    <meta
      property="og:title"
      content={finalTitle}
      data-seo-title-key={seoTitleKey}
      data-seo-title-fallback={seoTitleFallback ?? title}
    />
    <meta
      property="og:description"
      content={description}
      data-seo-description-key={seoDescriptionKey}
      data-seo-description-fallback={seoDescriptionFallback ?? description}
    />
    <meta property="og:image" content={ogImageUrl.toString()} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:type" content={ogType} />
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleTags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&family=Shippori+Mincho:wght@400;600&family=Zen+Old+Mincho:wght@400;700&display=swap"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body>
    {
      hasBackgroundAssets && (
        <div
          class="page-background"
          aria-hidden="true"
          data-page-background
          data-asset-default={backgroundAssets?.default}
          data-asset-dark={backgroundAssets?.dark}
          data-asset-light={backgroundAssets?.light}
        ></div>
      )
    }

    <SakuraCanvas />

    <div class="page-root">
      <ThemeSwitcher />
      <LanguageSwitcher />
      <slot />
    </div>

    <div class="global-vignette" aria-hidden="true"></div>
  </body>
</html>

<script>
  import { ui, type Lang } from '../i18n/ui';
  import { getLang, initI18n } from '../utils/i18n';
  import { getTheme, initTheme, resolveThemedAsset, type Theme } from '../utils/theme';

  function withSuffix(title: string): string {
    return title === 'PhSeCl' ? title : `${title} \u2014 PhSeCl`;
  }

  function applySeoTranslations(lang: Lang): void {
    const titleNode = document.querySelector('title[data-seo-title-key]');
    const descriptionMeta = document.querySelector(
      'meta[name="description"][data-seo-description-key]',
    );
    const ogTitleMeta = document.querySelector(
      'meta[property="og:title"][data-seo-title-key]',
    );
    const ogDescriptionMeta = document.querySelector(
      'meta[property="og:description"][data-seo-description-key]',
    );

    if (titleNode instanceof HTMLTitleElement) {
      const key = titleNode.dataset.seoTitleKey;
      const fallback = titleNode.dataset.seoTitleFallback ?? 'PhSeCl';
      const translated = key ? ui[lang][key] ?? fallback : fallback;
      const resolvedTitle = withSuffix(translated);
      titleNode.textContent = resolvedTitle;

      if (ogTitleMeta instanceof HTMLMetaElement) {
        ogTitleMeta.content = resolvedTitle;
      }
    }

    if (descriptionMeta instanceof HTMLMetaElement) {
      const key = descriptionMeta.dataset.seoDescriptionKey;
      const fallback = descriptionMeta.dataset.seoDescriptionFallback ?? '';
      descriptionMeta.content = key ? ui[lang][key] ?? fallback : fallback;
    }

    if (ogDescriptionMeta instanceof HTMLMetaElement) {
      const key = ogDescriptionMeta.dataset.seoDescriptionKey;
      const fallback = ogDescriptionMeta.dataset.seoDescriptionFallback ?? '';
      ogDescriptionMeta.content = key ? ui[lang][key] ?? fallback : fallback;
    }
  }

  function applyPageBackground(theme: Theme): void {
    const background = document.querySelector<HTMLElement>('[data-page-background]');

    if (!background) {
      return;
    }

    const asset = resolveThemedAsset(
      {
        default: background.dataset.assetDefault,
        dark: background.dataset.assetDark,
        light: background.dataset.assetLight,
      },
      theme,
    );

    background.style.backgroundImage = asset
      ? `var(--page-background-mask), url("${asset}")`
      : 'none';
    background.classList.toggle('is-empty', !asset);
  }

  function initPageState() {
    initI18n();
    applySeoTranslations(getLang());
    applyPageBackground(initTheme());
  }

  document.addEventListener('astro:page-load', initPageState);
  document.addEventListener('astro:after-swap', initPageState);
  window.addEventListener('lang-change', (event: Event) => {
    const detail = (event as CustomEvent<{ lang?: Lang }>).detail;
    applySeoTranslations(detail?.lang ?? getLang());
  });
  window.addEventListener('theme-change', (event: Event) => {
    const detail = (event as CustomEvent<{ theme?: Theme }>).detail;
    applyPageBackground(detail?.theme ?? getTheme());
  });
  initPageState();
</script>

<style>
  .page-root {
    position: relative;
    z-index: 2;
  }

  .page-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    transition: opacity 0.45s ease, filter 0.45s ease;
  }

  .page-background.is-empty {
    opacity: 0;
  }

  .global-vignette {
    position: fixed;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 120%, rgba(0, 0, 0, 0.5), transparent 42%),
      radial-gradient(circle at 50% -20%, rgba(255, 180, 210, 0.07), transparent 38%);
  }
</style>

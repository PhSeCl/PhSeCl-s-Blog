---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'PhSeCl',
  description = 'PhSeCl.com personal website',
} = Astro.props;
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>


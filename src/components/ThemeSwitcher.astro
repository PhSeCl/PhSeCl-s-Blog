<div class="theme-switcher" data-theme-switcher>
  <button class="theme-trigger" type="button" data-theme-toggle aria-haspopup="true" aria-expanded="false">
    <span data-theme-current>夜</span>
  </button>

  <div class="theme-menu" data-theme-menu hidden>
    <button class="theme-option" type="button" data-theme-option="dark">暗色</button>
    <button class="theme-option" type="button" data-theme-option="light">亮色</button>
  </div>
</div>

<script>
  import { type Theme } from '../utils/theme';
  import { getTheme, setTheme } from '../utils/theme';
  import { t } from '../utils/i18n';

  function initThemeSwitcher() {
    const root = document.querySelector<HTMLElement>('[data-theme-switcher]');

    if (!root || root.dataset.ready === 'true') {
      return;
    }

    root.dataset.ready = 'true';

    const toggle = root.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    const menu = root.querySelector<HTMLElement>('[data-theme-menu]');
    const current = root.querySelector<HTMLElement>('[data-theme-current]');
    const options = root.querySelectorAll<HTMLButtonElement>('[data-theme-option]');

    if (!toggle || !menu || !current) {
      return;
    }

    const updateLabel = (theme: Theme) => {
      current.textContent = t(`theme.current.${theme}`);
      toggle.setAttribute('aria-label', t('theme.menu'));

      options.forEach((option) => {
        const optionTheme = option.dataset.themeOption as Theme;
        option.textContent = t(`theme.option.${optionTheme}`);
      });
    };

    const closeMenu = () => {
      menu.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
    };

    const openMenu = () => {
      menu.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
    };

    updateLabel(getTheme());

    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      menu.hidden ? openMenu() : closeMenu();
    });

    options.forEach((option) => {
      option.addEventListener('click', () => {
        const nextTheme = option.dataset.themeOption as Theme;
        setTheme(nextTheme);
        updateLabel(nextTheme);
        closeMenu();
      });
    });

    document.addEventListener('click', (event) => {
      if (!root.contains(event.target as Node)) {
        closeMenu();
      }
    });

    window.addEventListener('theme-change', ((event: Event) => {
      const detail = (event as CustomEvent<{ theme: Theme }>).detail;
      updateLabel(detail.theme);
    }) as EventListener);

    window.addEventListener('lang-change', () => {
      updateLabel(getTheme());
    });
  }

  document.addEventListener('astro:page-load', initThemeSwitcher);
  document.addEventListener('astro:after-swap', initThemeSwitcher);
  initThemeSwitcher();
</script>

<style>
  .theme-switcher {
    position: fixed;
    top: 1.5rem;
    right: 6.2rem;
    z-index: 30;
    font-family: 'Noto Sans JP', sans-serif;
  }

  .theme-trigger,
  .theme-option {
    border: 1px solid var(--panel-border);
    background: var(--panel-bg-strong);
    color: var(--text-primary);
    cursor: pointer;
  }

  .theme-trigger {
    min-width: 3.8rem;
    padding: 0.55rem 0.8rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    backdrop-filter: blur(8px);
    transition:
      border-color 0.25s ease,
      transform 0.25s ease,
      background 0.25s ease;
  }

  .theme-trigger:hover {
    transform: translateY(-1px);
    border-color: var(--panel-border-strong);
    background: var(--panel-hover-bg);
  }

  .theme-menu {
    display: grid;
    gap: 0.35rem;
    margin-top: 0.55rem;
    padding: 0.45rem;
    border: 1px solid var(--panel-border);
    background: var(--panel-bg-strong);
    box-shadow: 0 16px 36px var(--panel-shadow);
    backdrop-filter: blur(10px);
  }

  .theme-option {
    min-width: 7rem;
    padding: 0.55rem 0.8rem;
    text-align: left;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    transition:
      color 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease;
  }

  .theme-option:hover {
    color: var(--sakura-50);
    border-color: var(--panel-border-strong);
    background: var(--panel-hover-bg);
  }

  @media (max-width: 767px) {
    .theme-switcher {
      top: 1rem;
      right: 5.4rem;
    }
  }
</style>

<div class="theme-switcher" data-theme-switcher>
  <button
    class="theme-toggle"
    type="button"
    role="switch"
    aria-checked="false"
    data-theme-toggle
  >
    <span class="theme-track" aria-hidden="true">
      <span class="theme-side theme-side-dark">
        <span class="theme-icon">☾</span>
        <span data-theme-label-dark>夜</span>
      </span>
      <span class="theme-side theme-side-light">
        <span data-theme-label-light>昼</span>
        <span class="theme-icon">☼</span>
      </span>
      <span class="theme-thumb">
        <span class="theme-thumb-glow"></span>
        <span class="theme-thumb-core"></span>
      </span>
    </span>
  </button>
</div>

<script>
  import { type Theme } from '../utils/theme';
  import { getTheme, setTheme } from '../utils/theme';
  import { t } from '../utils/i18n';

  function initThemeSwitcher() {
    const root = document.querySelector<HTMLElement>('[data-theme-switcher]');

    if (!root || root.dataset.ready === 'true') {
      return;
    }

    root.dataset.ready = 'true';

    const toggle = root.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    const darkLabel = root.querySelector<HTMLElement>('[data-theme-label-dark]');
    const lightLabel = root.querySelector<HTMLElement>('[data-theme-label-light]');

    if (!toggle || !darkLabel || !lightLabel) {
      return;
    }

    const updateToggle = (theme: Theme) => {
      const isLight = theme === 'light';
      root.dataset.themeState = theme;
      toggle.setAttribute('aria-checked', String(isLight));
      toggle.setAttribute('aria-label', `${t('theme.menu')}: ${t(`theme.option.${theme}`)}`);
      darkLabel.textContent = t('theme.current.dark');
      lightLabel.textContent = t('theme.current.light');
    };

    updateToggle(getTheme());

    toggle.addEventListener('click', () => {
      const nextTheme: Theme = getTheme() === 'dark' ? 'light' : 'dark';
      setTheme(nextTheme);
      updateToggle(nextTheme);
    });

    window.addEventListener('theme-change', ((event: Event) => {
      const detail = (event as CustomEvent<{ theme: Theme }>).detail;
      updateToggle(detail.theme);
    }) as EventListener);

    window.addEventListener('lang-change', () => {
      updateToggle(getTheme());
    });
  }

  document.addEventListener('astro:page-load', initThemeSwitcher);
  document.addEventListener('astro:after-swap', initThemeSwitcher);
  initThemeSwitcher();
</script>

<style>
  .theme-switcher {
    position: fixed;
    top: 1.5rem;
    right: 6.2rem;
    z-index: 30;
    font-family: 'Noto Sans JP', sans-serif;
  }

  .theme-toggle {
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
  }

  .theme-track {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    width: 6.75rem;
    height: 3rem;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--panel-border);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
      var(--panel-bg-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 14px 32px var(--panel-shadow);
    backdrop-filter: blur(14px);
    transition:
      border-color 0.28s ease,
      background 0.28s ease,
      box-shadow 0.28s ease,
      transform 0.28s ease;
  }

  .theme-toggle:hover .theme-track {
    border-color: var(--panel-border-strong);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.06)),
      var(--panel-bg-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 18px 38px var(--panel-shadow);
    transform: translateY(-1px);
  }

  .theme-toggle:active .theme-track {
    transform: translateY(0);
  }

  .theme-toggle:focus-visible .theme-track {
    outline: none;
    border-color: rgba(245, 184, 204, 0.55);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 0 0 4px rgba(212, 120, 154, 0.14),
      0 18px 38px var(--panel-shadow);
  }

  .theme-side {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    transition:
      color 0.28s ease,
      opacity 0.28s ease;
  }

  .theme-side-dark {
    color: var(--sakura-100);
    opacity: 0.95;
  }

  .theme-side-light {
    color: var(--text-muted);
    opacity: 0.72;
  }

  .theme-switcher[data-theme-state='light'] .theme-side-dark {
    color: var(--text-muted);
    opacity: 0.72;
  }

  .theme-switcher[data-theme-state='light'] .theme-side-light {
    color: var(--sakura-100);
    opacity: 0.95;
  }

  .theme-icon {
    font-size: 0.75rem;
    line-height: 1;
  }

  .theme-thumb {
    position: absolute;
    top: 0.28rem;
    left: 0.28rem;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 999px;
    transition:
      transform 0.34s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.28s ease,
      box-shadow 0.28s ease;
  }

  .theme-switcher[data-theme-state='light'] .theme-thumb {
    transform: translateX(3.84rem);
  }

  .theme-thumb-glow,
  .theme-thumb-core {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .theme-thumb-glow {
    inset: -0.08rem;
    background: radial-gradient(circle, rgba(245, 184, 204, 0.26), transparent 72%);
    opacity: 0.95;
  }

  .theme-thumb-core {
    border: 1px solid rgba(255, 255, 255, 0.24);
    background:
      linear-gradient(180deg, rgba(255, 248, 251, 0.92), rgba(236, 210, 222, 0.82));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 10px 18px rgba(0, 0, 0, 0.18);
  }

  .theme-switcher[data-theme-state='light'] .theme-thumb-core {
    background:
      linear-gradient(180deg, rgba(255, 252, 245, 0.96), rgba(255, 226, 175, 0.82));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.56),
      0 10px 18px rgba(160, 84, 112, 0.16);
  }

  @media (max-width: 767px) {
    .theme-switcher {
      top: 1rem;
      right: 5.35rem;
    }

    .theme-track {
      width: 6.2rem;
      height: 2.8rem;
      padding: 0.45rem 0.75rem;
    }

    .theme-thumb {
      width: 2.15rem;
      height: 2.15rem;
    }

    .theme-switcher[data-theme-state='light'] .theme-thumb {
      transform: translateX(3.24rem);
    }
  }
</style>

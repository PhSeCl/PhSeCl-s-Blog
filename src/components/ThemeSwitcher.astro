<div class="theme-switcher" data-theme-switcher>
  <button
    class="theme-toggle"
    type="button"
    role="switch"
    aria-checked="false"
    data-theme-toggle
  >
    <span class="sr-only" data-theme-announcer>Theme</span>
    <span class="theme-track" aria-hidden="true">
      <span class="theme-track-glow"></span>
      <span class="theme-icon theme-icon-dark">☾</span>
      <span class="theme-icon theme-icon-light">☼</span>
      <span class="theme-thumb">
        <span class="theme-thumb-core"></span>
      </span>
    </span>
  </button>
</div>

<script>
  import { type Theme } from '../utils/theme';
  import { getTheme, setTheme } from '../utils/theme';
  import { t } from '../utils/i18n';

  function initThemeSwitcher() {
    const root = document.querySelector<HTMLElement>('[data-theme-switcher]');

    if (!root || root.dataset.ready === 'true') {
      return;
    }

    root.dataset.ready = 'true';

    const toggle = root.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    const announcer = root.querySelector<HTMLElement>('[data-theme-announcer]');

    if (!toggle || !announcer) {
      return;
    }

    const updateToggle = (theme: Theme) => {
      const isLight = theme === 'light';
      root.dataset.themeState = theme;
      toggle.setAttribute('aria-checked', String(isLight));
      toggle.setAttribute('aria-label', `${t('theme.menu')}: ${t(`theme.option.${theme}`)}`);
      announcer.textContent = `${t('theme.menu')}: ${t(`theme.option.${theme}`)}`;
    };

    updateToggle(getTheme());

    toggle.addEventListener('click', () => {
      const nextTheme: Theme = getTheme() === 'dark' ? 'light' : 'dark';
      setTheme(nextTheme);
      updateToggle(nextTheme);
    });

    window.addEventListener('theme-change', ((event: Event) => {
      const detail = (event as CustomEvent<{ theme: Theme }>).detail;
      updateToggle(detail.theme);
    }) as EventListener);

    window.addEventListener('lang-change', () => {
      updateToggle(getTheme());
    });
  }

  document.addEventListener('astro:page-load', initThemeSwitcher);
  document.addEventListener('astro:after-swap', initThemeSwitcher);
  initThemeSwitcher();
</script>

<style>
  .theme-switcher {
    position: relative;
    z-index: 1;
    font-family: 'Noto Sans JP', sans-serif;
  }

  .theme-toggle {
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
  }

  .theme-track {
    position: relative;
    display: block;
    width: 2.9rem;
    height: 1.65rem;
    border: 1px solid var(--panel-border);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
      var(--panel-bg-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 8px 22px var(--panel-shadow);
    backdrop-filter: blur(14px);
    transition:
      border-color 0.28s ease,
      background 0.28s ease,
      box-shadow 0.28s ease,
      transform 0.28s ease;
  }

  .theme-toggle:hover .theme-track {
    border-color: var(--panel-border-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 10px 26px var(--panel-shadow);
    transform: translateY(-1px);
  }

  .theme-toggle:active .theme-track {
    transform: translateY(0);
  }

  .theme-toggle:focus-visible .theme-track {
    outline: none;
    border-color: rgba(245, 184, 204, 0.55);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 0 0 4px rgba(212, 120, 154, 0.14),
      0 10px 26px var(--panel-shadow);
  }

  .theme-track-glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at 28% 50%, rgba(212, 120, 154, 0.14), transparent 38%),
      radial-gradient(circle at 72% 50%, rgba(255, 226, 145, 0.08), transparent 34%);
    transition: opacity 0.28s ease, background 0.28s ease;
  }

  .theme-icon {
    position: absolute;
    top: 50%;
    z-index: 1;
    font-size: 0.58rem;
    line-height: 1;
    transform: translateY(-50%);
    transition: color 0.28s ease, opacity 0.28s ease;
  }

  .theme-icon-dark {
    left: 0.42rem;
    color: var(--text-heading);
    opacity: 0.85;
  }

  .theme-icon-light {
    right: 0.42rem;
    color: var(--text-muted);
    opacity: 0.44;
  }

  .theme-thumb {
    position: absolute;
    top: 0.12rem;
    left: 0.12rem;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    transition: transform 0.34s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .theme-thumb-core {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: inherit;
    background:
      linear-gradient(180deg, rgba(255, 248, 251, 0.96), rgba(236, 210, 222, 0.84));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 6px 12px rgba(0, 0, 0, 0.16);
    transition: background 0.28s ease, box-shadow 0.28s ease;
  }

  .theme-switcher[data-theme-state='light'] .theme-track-glow {
    background:
      radial-gradient(circle at 28% 50%, rgba(212, 120, 154, 0.08), transparent 34%),
      radial-gradient(circle at 72% 50%, rgba(255, 226, 145, 0.16), transparent 36%);
  }

  .theme-switcher[data-theme-state='light'] .theme-icon-dark {
    color: var(--text-muted);
    opacity: 0.42;
  }

  .theme-switcher[data-theme-state='light'] .theme-icon-light {
    color: #ffd98f;
    opacity: 0.96;
  }

  .theme-switcher[data-theme-state='light'] .theme-thumb {
    transform: translateX(1.3rem);
  }

  .theme-switcher[data-theme-state='light'] .theme-thumb-core {
    background:
      linear-gradient(180deg, rgba(255, 252, 245, 0.98), rgba(255, 226, 175, 0.88));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.56),
      0 6px 12px rgba(160, 84, 112, 0.12);
  }

  @media (max-width: 767px) {
    .theme-track {
      width: 2.7rem;
      height: 1.55rem;
    }

    .theme-icon-dark {
      left: 0.38rem;
    }

    .theme-icon-light {
      right: 0.38rem;
    }

    .theme-thumb {
      top: 0.11rem;
      left: 0.11rem;
      width: 1.28rem;
      height: 1.28rem;
    }

    .theme-switcher[data-theme-state='light'] .theme-thumb {
      transform: translateX(1.18rem);
    }
  }
</style>

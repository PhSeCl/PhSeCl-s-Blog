---
import {
  buildWorksPagination,
  getWorksPaginationPath,
  getWorksPageSlice,
  type WorkItem,
} from '../utils/works';

interface Props {
  works: WorkItem[];
  currentPage: number;
}

const { works, currentPage } = Astro.props;
const pagination = buildWorksPagination(works.length, currentPage);
const visibleWorks = getWorksPageSlice(works, pagination.currentPage);
---

<p class="page-intro" data-i18n="works.intro">
  一些已经完成、正在打磨，或者仍然在生长中的作品。
</p>

<section class="works-grid">
  {
    visibleWorks.length > 0 ? (
      visibleWorks.map((work) => (
        <article class="work-card">
          <div
            class="work-cover"
            aria-hidden="true"
            style={work.cover ? `--work-cover-image: url(${JSON.stringify(work.cover)})` : undefined}
          ></div>
          <div class="work-body">
            <h2>{work.title}</h2>
            <p>{work.description}</p>
            <div class="tag-list">
              {work.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
            <a href={work.url} target="_blank" rel="noreferrer">
              Visit →
            </a>
          </div>
        </article>
      ))
    ) : (
      <p class="empty-state" data-i18n="works.empty">
        作品页正在整理中，新的页面很快会在这里出现。
      </p>
    )
  }
</section>

{
  pagination.totalPages > 1 && (
    <nav class="pagination-nav" aria-label="Pagination">
      <div class="pagination-summary">
        <span>Page {pagination.currentPage}</span>
        <span>/</span>
        <span>{pagination.totalPages}</span>
      </div>

      <div class="pagination-links">
        {
          pagination.previousPage && (
            <a href={getWorksPaginationPath(pagination.previousPage)} rel="prev">
              上一页
            </a>
          )
        }

        {pagination.pages.map((page) => (
          <a
            href={getWorksPaginationPath(page)}
            aria-current={page === pagination.currentPage ? 'page' : undefined}
          >
            {page}
          </a>
        ))}

        {
          pagination.nextPage && (
            <a href={getWorksPaginationPath(pagination.nextPage)} rel="next">
              下一页
            </a>
          )
        }

        <a href={getWorksPaginationPath(pagination.lastPage)}>尾页</a>
      </div>
    </nav>
  )
}

<style>
  .page-intro {
    margin: 0 0 2rem;
    color: var(--text-soft);
    line-height: 1.9;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.6rem;
  }

  .empty-state {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.9;
    letter-spacing: 0.08em;
  }

  .work-card {
    display: flex;
    height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(220, 160, 190, 0.08);
    background: rgba(255, 255, 255, 0.02);
    transition:
      transform 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .work-card:hover {
    transform: translateY(-4px);
    border-color: rgba(220, 160, 190, 0.18);
    box-shadow: 0 20px 60px rgba(160, 60, 100, 0.08);
  }

  .work-cover {
    aspect-ratio: 16 / 9;
    background:
      var(--work-cover-image),
      linear-gradient(135deg, rgba(212, 120, 154, 0.12), transparent),
      rgba(255, 255, 255, 0.04);
    background-position: center;
    background-size: cover;
  }

  .work-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.35rem;
  }

  .work-body h2 {
    margin: 0 0 0.6rem;
    color: var(--text-heading);
    font-family: 'Zen Old Mincho', serif;
    font-size: 1.1rem;
    font-weight: 400;
  }

  .work-body p {
    margin: 0;
    overflow: hidden;
    color: var(--text-soft);
    line-height: 1.8;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag-list span {
    border: 1px solid rgba(160, 60, 100, 0.2);
    border-radius: 2px;
    padding: 0.24em 0.7em;
    color: var(--sakura-300);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
  }

  .work-body a {
    display: inline-block;
    margin-top: auto;
    padding-top: 1.15rem;
    color: var(--sakura-200);
    text-decoration: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
  }

  .pagination-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(220, 160, 190, 0.1);
  }

  .pagination-summary {
    display: inline-flex;
    gap: 0.45rem;
    color: var(--text-soft);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pagination-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.55rem;
  }

  .pagination-links a {
    border: 1px solid rgba(160, 60, 100, 0.2);
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    color: var(--text-soft);
    text-decoration: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    transition:
      border-color 0.3s ease,
      color 0.3s ease,
      background 0.3s ease;
  }

  .pagination-links a[aria-current='page'] {
    border-color: rgba(220, 160, 190, 0.28);
    background: rgba(220, 160, 190, 0.08);
    color: var(--text-heading);
  }

  .pagination-links a:hover {
    border-color: rgba(220, 160, 190, 0.28);
    color: var(--text-heading);
  }

  @media (max-width: 767px) {
    .pagination-nav {
      align-items: flex-start;
      flex-direction: column;
    }

    .pagination-links {
      justify-content: flex-start;
    }
  }
</style>

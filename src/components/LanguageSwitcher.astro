<div class="lang-switcher" data-lang-switcher>
  <button class="lang-trigger" type="button" data-lang-toggle aria-haspopup="true" aria-expanded="false">
    <span data-lang-current>中</span>
  </button>

  <div class="lang-menu" data-lang-menu hidden>
    <button class="lang-option" type="button" data-lang-option="zh">中文</button>
    <button class="lang-option" type="button" data-lang-option="ja">日本語</button>
    <button class="lang-option" type="button" data-lang-option="en">English</button>
  </div>
</div>

<script>
  import { languages, type Lang } from '../i18n/ui';
  import { getLang, setLang, t } from '../utils/i18n';

  function initLanguageSwitcher() {
    const root = document.querySelector<HTMLElement>('[data-lang-switcher]');

    if (!root || root.dataset.ready === 'true') {
      return;
    }

    root.dataset.ready = 'true';

    const toggle = root.querySelector<HTMLButtonElement>('[data-lang-toggle]');
    const menu = root.querySelector<HTMLElement>('[data-lang-menu]');
    const current = root.querySelector<HTMLElement>('[data-lang-current]');
    const options = root.querySelectorAll<HTMLButtonElement>('[data-lang-option]');

    if (!toggle || !menu || !current) {
      return;
    }

    const updateLabel = (lang: Lang) => {
      current.textContent = t(`switcher.current.${lang}`);
      toggle.setAttribute('aria-label', t('switcher.menu'));

      options.forEach((option) => {
        const optionLang = option.dataset.langOption as Lang;
        option.textContent = languages[optionLang];
      });
    };

    const closeMenu = () => {
      menu.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
    };

    const openMenu = () => {
      menu.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
    };

    updateLabel(getLang());

    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      menu.hidden ? openMenu() : closeMenu();
    });

    options.forEach((option) => {
      option.addEventListener('click', () => {
        const nextLang = option.dataset.langOption as Lang;
        setLang(nextLang);
        closeMenu();
      });
    });

    document.addEventListener('click', (event) => {
      if (!root.contains(event.target as Node)) {
        closeMenu();
      }
    });

    window.addEventListener('lang-change', ((event: Event) => {
      const detail = (event as CustomEvent<{ lang: Lang }>).detail;
      updateLabel(detail.lang);
    }) as EventListener);
  }

  document.addEventListener('astro:page-load', initLanguageSwitcher);
  document.addEventListener('astro:after-swap', initLanguageSwitcher);
  initLanguageSwitcher();
</script>

<style>
  .lang-switcher {
    position: relative;
    z-index: 1;
    font-family: 'Noto Sans JP', sans-serif;
  }

  .lang-trigger,
  .lang-option {
    border: 1px solid var(--panel-border);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
      var(--panel-bg-strong);
    color: var(--text-primary);
    border-radius: 999px;
    cursor: pointer;
  }

  .lang-trigger {
    min-width: 3.4rem;
    padding: 0.55rem 0.8rem;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    backdrop-filter: blur(14px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 8px 22px var(--panel-shadow);
    transition:
      border-color 0.28s ease,
      transform 0.28s ease,
      background 0.28s ease,
      box-shadow 0.28s ease;
  }

  .lang-trigger:hover {
    transform: translateY(-1px);
    border-color: var(--panel-border-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 10px 26px var(--panel-shadow);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 0.55rem);
    right: 0;
    display: grid;
    gap: 0.35rem;
    padding: 0.45rem;
    border: 1px solid var(--panel-border);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
      var(--panel-bg-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 12px 28px var(--panel-shadow);
    backdrop-filter: blur(14px);
  }

  .lang-option {
    min-width: 7rem;
    padding: 0.55rem 0.8rem;
    text-align: left;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition:
      color 0.28s ease,
      border-color 0.28s ease,
      background 0.28s ease,
      transform 0.28s ease,
      box-shadow 0.28s ease;
  }

  .lang-option:hover {
    color: var(--text-heading);
    border-color: var(--panel-border-strong);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
    transform: translateX(2px);
  }
</style>

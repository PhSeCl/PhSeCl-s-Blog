---
interface Props {
  backFallback?: string;
}

const { backFallback = '/' } = Astro.props;
---

<nav class="subpage-actions" aria-label="Page actions">
  <button
    class="subpage-action is-button"
    type="button"
    data-page-back
    data-fallback={backFallback}
    data-i18n="action.back"
  >
    Back
  </button>
  <a class="subpage-action" href="/" data-i18n="action.home">Home</a>
</nav>

<script>
  function initSubpageActions() {
    document.querySelectorAll<HTMLButtonElement>('[data-page-back]').forEach((button) => {
      if (button.dataset.backReady === 'true') {
        return;
      }

      button.dataset.backReady = 'true';
      button.addEventListener('click', () => {
        const fallback = button.dataset.fallback || '/';

        if (window.history.length > 1) {
          window.history.back();
          return;
        }

        window.location.href = fallback;
      });
    });
  }

  document.addEventListener('astro:page-load', initSubpageActions);
  document.addEventListener('astro:after-swap', initSubpageActions);
  initSubpageActions();
</script>

<style>
  .subpage-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }

  .subpage-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 8.8rem;
    padding: 0.75rem 1.1rem;
    border: 1px solid var(--panel-border);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
      var(--panel-bg-strong);
    backdrop-filter: blur(14px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 8px 22px var(--panel-shadow);
    color: var(--text-primary);
    text-decoration: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    transition:
      transform 0.28s ease,
      border-color 0.28s ease,
      background 0.28s ease,
      box-shadow 0.28s ease;
  }

  .subpage-action.is-button {
    cursor: pointer;
  }

  .subpage-action:hover {
    transform: translateY(-1px);
    border-color: var(--panel-border-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 10px 26px var(--panel-shadow);
  }

  @media (max-width: 767px) {
    .subpage-actions {
      gap: 0.7rem;
      margin-bottom: 1.5rem;
    }

    .subpage-action {
      min-width: 0;
      flex: 1 1 10rem;
    }
  }
</style>

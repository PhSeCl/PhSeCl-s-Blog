---
interface Props {
  backFallback?: string;
}

const { backFallback = '/' } = Astro.props;
---

<nav class="subpage-actions" aria-label="Page actions">
  <button
    class="subpage-action is-button"
    type="button"
    data-page-back
    data-fallback={backFallback}
    data-i18n="action.back"
  >
    返回上一级
  </button>
  <a class="subpage-action" href="/" data-i18n="action.home">返回首页</a>
</nav>

<script>
  function initSubpageActions() {
    document.querySelectorAll<HTMLButtonElement>('[data-page-back]').forEach((button) => {
      if (button.dataset.backReady === 'true') {
        return;
      }

      button.dataset.backReady = 'true';
      button.addEventListener('click', () => {
        const fallback = button.dataset.fallback || '/';

        if (window.history.length > 1) {
          window.history.back();
          return;
        }

        window.location.href = fallback;
      });
    });
  }

  document.addEventListener('astro:page-load', initSubpageActions);
  document.addEventListener('astro:after-swap', initSubpageActions);
  initSubpageActions();
</script>

<style>
  .subpage-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }

  .subpage-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 8.8rem;
    padding: 0.75rem 1.1rem;
    border: 1px solid rgba(220, 160, 190, 0.18);
    background: rgba(255, 255, 255, 0.02);
    color: var(--sakura-100);
    text-decoration: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
  }

  .subpage-action.is-button {
    cursor: pointer;
  }

  .subpage-action:hover {
    transform: translateY(-2px);
    border-color: rgba(245, 184, 204, 0.34);
    background: rgba(160, 64, 96, 0.1);
    box-shadow: 0 12px 30px rgba(160, 60, 100, 0.08);
  }

  @media (max-width: 767px) {
    .subpage-actions {
      gap: 0.7rem;
      margin-bottom: 1.5rem;
    }

    .subpage-action {
      min-width: 0;
      flex: 1 1 10rem;
    }
  }
</style>

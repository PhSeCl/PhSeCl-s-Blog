---
import { formatBlogDate } from '../utils/blog';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  slug: string;
}

const {
  title,
  description,
  date,
  tags = [],
  slug,
} = Astro.props;

const href = `/blog/${slug}`;
---

<article class="blog-card">
  <a class="blog-card-link" href={href} aria-label={`Read ${title}`}>
    <div class="date">{formatBlogDate(date)}</div>
    <h3>{title}</h3>
    <p>{description}</p>
  </a>

  {
    tags.length > 0 && (
      <div class="tag-row">
        {tags.map((tag) => (
          <a class="tag" href={`/tags/${encodeURIComponent(tag)}`}>
            {tag}
          </a>
        ))}
      </div>
    )
  }
</article>

<style>
  .blog-card {
    height: 100%;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(220, 160, 190, 0.08);
    border-radius: 4px;
    padding: 2rem;
    transition:
      transform 0.45s ease,
      border-color 0.45s ease,
      background 0.45s ease,
      box-shadow 0.45s ease;
  }

  .blog-card:hover {
    background: rgba(220, 160, 190, 0.045);
    border-color: rgba(220, 160, 190, 0.18);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(160, 60, 100, 0.08);
  }

  .blog-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .date {
    margin-bottom: 0.8rem;
    color: var(--text-muted);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
  }

  .blog-card h3 {
    margin: 0 0 0.8rem;
    color: var(--text-heading);
    font-family: 'Zen Old Mincho', serif;
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.6;
  }

  .blog-card p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.82rem;
    line-height: 1.8;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .tag {
    display: inline-block;
    border: 1px solid rgba(160, 60, 100, 0.2);
    border-radius: 2px;
    padding: 0.2em 0.8em;
    color: var(--sakura-400);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    opacity: 0.72;
    text-decoration: none;
    transition:
      border-color 0.3s ease,
      color 0.3s ease,
      opacity 0.3s ease;
  }

  .tag:hover {
    border-color: rgba(212, 120, 154, 0.38);
    color: var(--text-emphasis);
    opacity: 1;
  }
</style>

---
import works from '../data/works.json';
import PageLayout from '../layouts/PageLayout.astro';

interface WorkItem {
  title: string;
  description: string;
  tags: string[];
  url: string;
  cover: string;
}

const workItems = works as WorkItem[];
---

<PageLayout
  title="WORKS"
  description="展示基于 Astro、Canvas 与前端设计语言构建的作品与实验。"
  titleKey="page.works"
  titleFallback="WORKS"
  seoTitleKey="seo.works.title"
  seoDescriptionKey="seo.works.description"
  seoTitleFallback="WORKS"
  seoDescriptionFallback="展示基于 Astro、Canvas 与前端设计语言构建的作品与实验。"
>
  <p class="page-intro" data-i18n="works.intro">
    一些已经完成、正在打磨，或者仍然在生长中的作品。
  </p>

  <section class="works-grid">
    {
      workItems.length > 0 ? (
        workItems.map((work) => (
          <article class="work-card">
            <div class="work-cover" aria-hidden="true"></div>
            <div class="work-body">
              <h2>{work.title}</h2>
              <p>{work.description}</p>
              <div class="tag-list">
                {work.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
              <a href={work.url} target="_blank" rel="noreferrer">
                Visit →
              </a>
            </div>
          </article>
        ))
      ) : (
        <p class="empty-state" data-i18n="works.empty">
          作品页正在整理中，新的页面很快会在这里出现。
        </p>
      )
    }
  </section>
</PageLayout>

<style>
  .page-intro {
    margin: 0 0 2rem;
    color: var(--text-soft);
    line-height: 1.9;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.6rem;
  }

  .empty-state {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.9;
    letter-spacing: 0.08em;
  }

  .work-card {
    overflow: hidden;
    border: 1px solid rgba(220, 160, 190, 0.08);
    background: rgba(255, 255, 255, 0.02);
    transition:
      transform 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .work-card:hover {
    transform: translateY(-4px);
    border-color: rgba(220, 160, 190, 0.18);
    box-shadow: 0 20px 60px rgba(160, 60, 100, 0.08);
  }

  .work-cover {
    aspect-ratio: 16 / 9;
    background:
      linear-gradient(135deg, rgba(212, 120, 154, 0.12), transparent),
      rgba(255, 255, 255, 0.04);
  }

  .work-body {
    padding: 1.35rem;
  }

  .work-body h2 {
    margin: 0 0 0.6rem;
    color: var(--text-heading);
    font-family: 'Zen Old Mincho', serif;
    font-size: 1.1rem;
    font-weight: 400;
  }

  .work-body p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.8;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag-list span {
    border: 1px solid rgba(160, 60, 100, 0.2);
    border-radius: 2px;
    padding: 0.24em 0.7em;
    color: var(--sakura-300);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
  }

  .work-body a {
    display: inline-block;
    margin-top: 1.15rem;
    color: var(--sakura-200);
    text-decoration: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
  }
</style>

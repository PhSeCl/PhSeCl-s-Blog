---
import WorksDirectory from '../components/WorksDirectory.astro';
import works from '../data/works.json';
import PageLayout from '../layouts/PageLayout.astro';
import type { WorkItem } from '../utils/works';

const workItems = works as WorkItem[];
---

<PageLayout
  title="WORKS"
  description="展示基于 Astro、Canvas 与前端设计语言构建的作品与实验。"
  titleKey="page.works"
  titleFallback="WORKS"
  seoTitleKey="seo.works.title"
  seoDescriptionKey="seo.works.description"
  seoTitleFallback="WORKS"
  seoDescriptionFallback="展示基于 Astro、Canvas 与前端设计语言构建的作品与实验。"
>
  <WorksDirectory works={workItems} currentPage={1} />
</PageLayout>

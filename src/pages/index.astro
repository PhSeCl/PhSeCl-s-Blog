---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="PhSeCl" description="PhSeCl.com under construction">
  <main class="mx-auto flex min-h-screen max-w-6xl items-center justify-center px-6 py-20 text-center">
    <div>
      <p class="font-ui text-sm uppercase tracking-[0.4em] text-text-muted">PhSeCl.com</p>
      <h1 class="mt-4 font-display text-5xl text-sakura-100">Site Foundation Ready</h1>
      <p class="mt-6 text-base text-text-muted">
        The homepage visual module will be implemented next.
      </p>
    </div>
  </main>
</BaseLayout>


---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import VideoHero from '../components/VideoHero.astro';
import { sortBlogPosts } from '../utils/blog';

const latestPosts = sortBlogPosts(
  await getCollection('blog', ({ data }) => !data.draft),
).slice(0, 6);
---

<BaseLayout
  title="PhSeCl"
  description="樱花夜色中的个人博客与作品主页，记录代码、生活与创作。"
  seoTitleKey="seo.home.title"
  seoDescriptionKey="seo.home.description"
  seoTitleFallback="PhSeCl"
  seoDescriptionFallback="樱花夜色中的个人博客与作品主页，记录代码、生活与创作。"
>
  <main>
    <VideoHero />

    <section class="blog-section" id="latest-posts">
      <div class="section-header">
        <h2 data-i18n="blog.latest">最新の記事</h2>
        <div class="line"></div>
      </div>

      <div class="blog-grid">
        {
          latestPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              slug={post.id}
            />
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .blog-section {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    background: linear-gradient(to bottom, var(--bg-deep) 0%, var(--bg-surface) 100%);
    padding: 6rem 8%;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1.5em;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    margin: 0;
    color: var(--text-heading);
    font-family: 'Zen Old Mincho', serif;
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.15em;
  }

  .section-header .line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(220, 160, 190, 0.22), transparent);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 767px) {
    .blog-section {
      padding: 4rem 1.5rem;
    }

    .section-header {
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .section-header h2 {
      font-size: 1.1rem;
      letter-spacing: 0.1em;
    }
  }
</style>

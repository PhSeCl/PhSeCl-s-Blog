---
import friends from '../data/friends.json';
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="FRIENDS"
  description="收藏一些值得常去拜访的站点与朋友链接。"
  titleKey="page.friends"
  titleFallback="FRIENDS"
  seoTitleKey="seo.friends.title"
  seoDescriptionKey="seo.friends.description"
  seoTitleFallback="FRIENDS"
  seoDescriptionFallback="收藏一些值得常去拜访的站点与朋友链接。"
>
  <p class="page-intro" data-i18n="friends.intro">
    一些值得常去坐坐的站点。未来这里会继续慢慢补全。
  </p>

  <section class="friends-grid">
    {
      friends.length > 0 ? (
        friends.map((friend) => (
          <article class="friend-card">
            <div class="friend-avatar">
              <div class="friend-avatar-fallback" aria-hidden="true"></div>
              <img src={friend.avatar} alt="" onerror="this.classList.add('is-hidden')" />
            </div>
            <div class="friend-body">
              <h2>{friend.name}</h2>
              <p>{friend.description}</p>
              <a href={friend.url} target="_blank" rel="noreferrer">
                {friend.url}
              </a>
            </div>
          </article>
        ))
      ) : (
        <p class="empty-state" data-i18n="friends.empty">
          友链还在整理中，等风景慢慢聚齐。
        </p>
      )
    }
  </section>
</PageLayout>

<style>
  .page-intro {
    margin: 0 0 2rem;
    color: var(--text-soft);
    line-height: 1.9;
  }

  .friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.6rem;
  }

  .empty-state {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.9;
    letter-spacing: 0.08em;
  }

  .friend-card {
    display: flex;
    gap: 1rem;
    padding: 1.35rem;
    border: 1px solid rgba(220, 160, 190, 0.08);
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.02)),
      var(--panel-bg);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 10px 28px rgba(160, 60, 100, 0.05);
    transition:
      transform 0.4s ease,
      border-color 0.4s ease,
      background 0.4s ease,
      box-shadow 0.4s ease;
  }

  .friend-card:hover {
    transform: translateY(-4px);
    border-color: rgba(220, 160, 190, 0.18);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 20px 60px rgba(160, 60, 100, 0.08);
  }

  .friend-avatar {
    position: relative;
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }

  .friend-avatar-fallback,
  .friend-avatar img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 999px;
  }

  .friend-avatar-fallback {
    background: radial-gradient(circle at 30% 30%, rgba(245, 184, 204, 0.72), rgba(122, 46, 74, 0.58));
  }

  .friend-avatar img {
    object-fit: cover;
  }

  .friend-avatar img.is-hidden {
    opacity: 0;
  }

  .friend-body h2 {
    margin: 0 0 0.4rem;
    color: var(--text-heading);
    font-family: 'Zen Old Mincho', serif;
    font-size: 1rem;
    font-weight: 400;
  }

  .friend-body p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.8;
  }

  .friend-body a {
    display: inline-block;
    margin-top: 0.9rem;
    color: var(--sakura-300);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    text-decoration: none;
    letter-spacing: 0.08em;
    word-break: break-all;
  }
</style>

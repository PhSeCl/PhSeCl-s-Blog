---
import friends from '../data/friends.json';
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="FRIENDS"
  description="收藏一些值得常去拜访的站点与朋友链接。"
  titleKey="page.friends"
  titleFallback="FRIENDS"
  seoTitleKey="seo.friends.title"
  seoDescriptionKey="seo.friends.description"
  seoTitleFallback="FRIENDS"
  seoDescriptionFallback="收藏一些值得常去拜访的站点与朋友链接。"
>
  <p class="page-intro" data-i18n="friends.intro">
    一些值得常去坐坐的站点。未来这里会继续慢慢补全。
  </p>

  <section class="friends-grid">
    {
      friends.map((friend) => (
        <article class="friend-card">
          <div class="friend-avatar">
            <div class="friend-avatar-fallback" aria-hidden="true"></div>
            <img src={friend.avatar} alt="" onerror="this.classList.add('is-hidden')" />
          </div>
          <div class="friend-body">
            <h2>{friend.name}</h2>
            <p>{friend.description}</p>
            <a href={friend.url} target="_blank" rel="noreferrer">
              {friend.url}
            </a>
          </div>
        </article>
      ))
    }
  </section>
</PageLayout>

<style>
  .page-intro {
    margin: 0 0 2rem;
    color: rgba(224, 198, 210, 0.74);
    line-height: 1.9;
  }

  .friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.6rem;
  }

  .friend-card {
    display: flex;
    gap: 1rem;
    padding: 1.35rem;
    border: 1px solid rgba(220, 160, 190, 0.08);
    background: rgba(255, 255, 255, 0.02);
    transition:
      transform 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .friend-card:hover {
    transform: translateY(-4px);
    border-color: rgba(220, 160, 190, 0.18);
    box-shadow: 0 20px 60px rgba(160, 60, 100, 0.08);
  }

  .friend-avatar {
    position: relative;
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }

  .friend-avatar-fallback,
  .friend-avatar img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 999px;
  }

  .friend-avatar-fallback {
    background: radial-gradient(circle at 30% 30%, rgba(245, 184, 204, 0.72), rgba(122, 46, 74, 0.58));
  }

  .friend-avatar img {
    object-fit: cover;
  }

  .friend-avatar img.is-hidden {
    opacity: 0;
  }

  .friend-body h2 {
    margin: 0 0 0.4rem;
    color: var(--sakura-100);
    font-family: 'Zen Old Mincho', serif;
    font-size: 1rem;
    font-weight: 400;
  }

  .friend-body p {
    margin: 0;
    color: rgba(210, 180, 194, 0.68);
    line-height: 1.8;
  }

  .friend-body a {
    display: inline-block;
    margin-top: 0.9rem;
    color: var(--sakura-300);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    text-decoration: none;
    letter-spacing: 0.08em;
    word-break: break-all;
  }
</style>

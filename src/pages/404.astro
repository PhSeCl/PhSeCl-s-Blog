---
import SubpageActions from '../components/SubpageActions.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404"
  description="页面不存在，这片花瓣飘到了未被命名的地方。"
  seoTitleKey="seo.notfound.title"
  seoDescriptionKey="seo.notfound.description"
  seoTitleFallback="404"
  seoDescriptionFallback="页面不存在，这片花瓣飘到了未被命名的地方。"
>
  <main class="notfound-layout">
    <section class="notfound-shell">
      <SubpageActions backFallback="/" />
      <p class="notfound-code" data-i18n="page.notfound">404</p>
      <p class="notfound-copy" data-i18n="notfound.message">
        ページが見つかりません — 这片花瓣飘到了不存在的地方
      </p>
      <a class="notfound-link" href="/" data-i18n="notfound.back">返回首页</a>
    </section>
  </main>
</BaseLayout>

<style>
  .notfound-layout {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .notfound-shell {
    width: min(100%, 42rem);
    text-align: center;
  }

  .notfound-shell :global(.subpage-actions) {
    justify-content: center;
  }

  .notfound-code {
    margin: 0;
    color: rgba(245, 184, 204, 0.5);
    font-family: 'Zen Old Mincho', serif;
    font-size: clamp(5rem, 16vw, 10rem);
    line-height: 1;
    letter-spacing: 0.08em;
  }

  .notfound-copy {
    margin: 1rem auto 2rem;
    max-width: 40rem;
    color: var(--text-primary);
    font-size: 1rem;
    letter-spacing: 0.08em;
    line-height: 1.9;
  }

  .notfound-link {
    display: inline-block;
    padding: 0.8rem 1.3rem;
    border: 1px solid rgba(220, 160, 190, 0.22);
    color: var(--text-heading);
    text-decoration: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      background 0.3s ease;
  }

  .notfound-link:hover {
    transform: translateY(-2px);
    border-color: rgba(245, 184, 204, 0.38);
    background: rgba(160, 64, 96, 0.12);
  }
</style>

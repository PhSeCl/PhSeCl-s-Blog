---
import picks from '../data/picks.json';
import PageLayout from '../layouts/PageLayout.astro';
import type { Lang } from '../i18n/ui';

type PickTitleLang = 'zh' | 'ja' | 'en';

interface PickItemTitle {
  zh?: string;
  ja?: string;
  en?: string;
  display?: PickTitleLang[];
}

interface PickItem {
  title: string | PickItemTitle;
  artist?: string;
  description: string;
  cover: string | null;
  url: string;
  tags: string[];
}

interface PickCategory {
  id: string;
  label: Record<Lang, string>;
  icon: string;
  featured?: number;
  items: PickItem[];
}

const categories = picks.categories as PickCategory[];

const iconMap: Record<string, string> = {
  gamepad: 'GAME',
  music: 'MUSIC',
  code: 'CODE',
};

const emptyState = {
  zh: '这里暂时什么也没有',
  ja: 'ここにはまだ何もありません',
  en: 'There is nothing here for now',
};

const actionLabels = {
  open: {
    zh: '打开链接',
    ja: 'リンクを開く',
    en: 'Open link',
  },
  expand: {
    zh: '展开简介',
    ja: '説明を開く',
    en: 'Expand',
  },
  collapse: {
    zh: '收起简介',
    ja: '説明を閉じる',
    en: 'Collapse',
  },
};

function resolvePickTitle(title: string | PickItemTitle): { main: string; alt?: string } {
  if (typeof title === 'string') {
    return { main: title };
  }

  const normalizedDisplay =
    title.display?.filter((lang, index, array) => array.indexOf(lang) === index && title[lang]) ?? [];

  const orderedDisplay = normalizedDisplay.includes('zh')
    ? ['zh', ...normalizedDisplay.filter((lang) => lang !== 'zh')]
    : normalizedDisplay;

  const [mainLang, altLang] = orderedDisplay;
  const main = (mainLang && title[mainLang]) || title.zh || title.ja || title.en || '';
  const alt = altLang && title[altLang] && title[altLang] !== main ? title[altLang] : undefined;

  return { main, alt };
}
---

<PageLayout
  title="精选"
  description="我喜欢的游戏、音乐和项目"
  titleKey="picks.title"
  titleFallback="精选"
  seoTitleKey="picks.title"
  seoDescriptionKey="picks.description"
  seoTitleFallback="精选"
  seoDescriptionFallback="我喜欢的游戏、音乐和项目"
>
  <p class="page-intro" data-i18n="picks.description">
    我喜欢的游戏、音乐和项目
  </p>

  <nav class="picks-filter" aria-label="Picks categories">
    {
      categories.map((category) => (
        <a
          href={`#${category.id}`}
          class="picks-filter-link"
          data-label-zh={category.label.zh}
          data-label-ja={category.label.ja}
          data-label-en={category.label.en}
        >
          {category.label.zh}
        </a>
      ))
    }
  </nav>

  <div class="picks-sections">
    {
      categories.map((category) => (
        (() => {
          const featuredItem = category.items[category.featured];
          const hasFeaturedItem = featuredItem !== undefined;
          const hasItems = category.items.length > 0;
          const orderedItems = featuredItem
            ? [featuredItem, ...category.items.filter((item) => item !== featuredItem)]
            : category.items;

          return (
            <section class="pick-section" id={category.id}>
              <div class="section-header">
                <h2
                  data-picks-label
                  data-label-zh={category.label.zh}
                  data-label-ja={category.label.ja}
                  data-label-en={category.label.en}
                >
                  {category.label.zh}
                </h2>
                <span class="section-icon" aria-hidden="true">{iconMap[category.icon] ?? category.icon}</span>
                <div class="line"></div>
              </div>

              {
                hasItems ? (
                  <div class="picks-grid">
                    {
                      orderedItems.map((item, itemIndex) => {
                        const resolvedTitle = resolvePickTitle(item.title);

                        return (
                          <article
                            class:list={{
                              'pick-card': true,
                              'pick-card-featured': itemIndex === 0 && hasFeaturedItem,
                            }}
                            data-expanded="false"
                            data-url={item.url}
                            tabindex="0"
                            role="link"
                            aria-label={resolvedTitle.main}
                          >
                            <div class="pick-cover" data-error="false">
                              <div class="pick-cover-fallback" aria-hidden="true"></div>
                              {item.cover && (
                                <img
                                  src={item.cover}
                                  alt=""
                                  loading="lazy"
                                  decoding="async"
                                  onerror="this.closest('.pick-cover')?.setAttribute('data-error', 'true')"
                                />
                              )}
                              {
                                itemIndex === 0 && hasFeaturedItem ? (
                                  <span class="pick-badge" data-i18n="picks.featured">置顶</span>
                                ) : null
                              }
                            </div>

                            <div class="pick-body">
                              <h3>
                                <span class="pick-title-main">{resolvedTitle.main}</span>
                                {resolvedTitle.alt && <span class="pick-title-alt">{resolvedTitle.alt}</span>}
                              </h3>
                              {item.artist && <p class="pick-artist">{item.artist}</p>}
                              <p class="pick-description">{item.description}</p>

                              <div class="pick-footer">
                                <div class="tag-row">
                                  {item.tags.map((tag) => (
                                    <span class="tag">{tag}</span>
                                  ))}
                                </div>

                                <div class="pick-actions">
                                  <button
                                    type="button"
                                    class="pick-expand-toggle"
                                    aria-expanded="false"
                                    data-pick-toggle
                                    data-expand-zh={actionLabels.expand.zh}
                                    data-expand-ja={actionLabels.expand.ja}
                                    data-expand-en={actionLabels.expand.en}
                                    data-collapse-zh={actionLabels.collapse.zh}
                                    data-collapse-ja={actionLabels.collapse.ja}
                                    data-collapse-en={actionLabels.collapse.en}
                                  >
                                    {actionLabels.expand.zh}
                                  </button>
                                  <a
                                    class="pick-open-link"
                                    href={item.url}
                                    target="_blank"
                                    rel="noreferrer"
                                    data-label-zh={actionLabels.open.zh}
                                    data-label-ja={actionLabels.open.ja}
                                    data-label-en={actionLabels.open.en}
                                  >
                                    {actionLabels.open.zh}
                                  </a>
                                </div>
                              </div>
                            </div>
                          </article>
                        );
                      })
                    }
                  </div>
                ) : (
                  <div
                    class="pick-empty"
                    aria-live="polite"
                    data-label-zh={emptyState.zh}
                    data-label-ja={emptyState.ja}
                    data-label-en={emptyState.en}
                  >
                    {emptyState.zh}
                  </div>
                )
              }
            </section>
          );
        })()
      ))
    }
  </div>
</PageLayout>

<script>
  import { getLang } from '../utils/i18n';
  import type { Lang } from '../i18n/ui';

  function resolveButtonLabel(button: HTMLButtonElement, lang: Lang) {
    const isExpanded = button.getAttribute('aria-expanded') === 'true';
    const prefix = isExpanded ? 'collapse' : 'expand';

    return (
      (lang === 'ja'
        ? button.dataset[`${prefix}Ja`]
        : lang === 'en'
          ? button.dataset[`${prefix}En`]
          : button.dataset[`${prefix}Zh`]) ?? button.dataset[`${prefix}Zh`]
    );
  }

  function applyPicksLabels(lang: Lang) {
    const nodes = document.querySelectorAll<HTMLElement>('[data-label-zh][data-label-ja][data-label-en]');
    const toggleButtons = document.querySelectorAll<HTMLButtonElement>('[data-pick-toggle]');

    nodes.forEach((node) => {
      const nextLabel =
        (lang === 'ja' ? node.dataset.labelJa : lang === 'en' ? node.dataset.labelEn : node.dataset.labelZh) ??
        node.dataset.labelZh;

      if (nextLabel) {
        node.textContent = nextLabel;
      }
    });

    toggleButtons.forEach((button) => {
      const nextLabel = resolveButtonLabel(button, lang);

      if (nextLabel) {
        button.textContent = nextLabel;
      }
    });
  }

  function bindPickDescriptionToggles() {
    const toggleButtons = document.querySelectorAll<HTMLButtonElement>('[data-pick-toggle]');
    const isMobileViewport = window.matchMedia('(max-width: 767px)').matches;

    toggleButtons.forEach((button) => {
      if (button.dataset.bound === 'true') {
        return;
      }

      button.dataset.bound = 'true';
      button.addEventListener('click', () => {
        if (!isMobileViewport) {
          return;
        }

        const card = button.closest<HTMLElement>('.pick-card');

        if (!card) {
          return;
        }

        const nextExpanded = card.dataset.expanded !== 'true';
        card.dataset.expanded = nextExpanded ? 'true' : 'false';
        button.setAttribute('aria-expanded', nextExpanded ? 'true' : 'false');
        applyPicksLabels(getLang());
      });
    });
  }

  function bindPickCardLinks() {
    const cards = document.querySelectorAll<HTMLElement>('.pick-card[data-url]');

    cards.forEach((card) => {
      if (card.dataset.linkBound === 'true') {
        return;
      }

      card.dataset.linkBound = 'true';

      const openCardLink = () => {
        if (window.matchMedia('(max-width: 767px)').matches) {
          return;
        }

        const url = card.dataset.url;

        if (url) {
          window.open(url, '_blank', 'noopener,noreferrer');
        }
      };

      card.addEventListener('click', (event) => {
        const target = event.target as HTMLElement | null;

        if (target?.closest('.pick-actions')) {
          return;
        }

        openCardLink();
      });

      card.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') {
          return;
        }

        const target = event.target as HTMLElement | null;

        if (target?.closest('.pick-actions')) {
          return;
        }

        event.preventDefault();
        openCardLink();
      });
    });
  }

  function initPicksPage() {
    bindPickDescriptionToggles();
    bindPickCardLinks();
    applyPicksLabels(getLang());
  }

  document.addEventListener('astro:page-load', initPicksPage);
  document.addEventListener('astro:after-swap', initPicksPage);
  window.addEventListener('lang-change', (event: Event) => {
    const detail = (event as CustomEvent<{ lang?: Lang }>).detail;
    applyPicksLabels(detail?.lang ?? getLang());
  });
  initPicksPage();
</script>

<style>
  .page-intro {
    margin: 0 0 1.8rem;
    color: var(--text-soft);
    line-height: 1.9;
  }

  .picks-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: 2.6rem;
  }

  .picks-filter-link {
    border: 1px solid rgba(160, 60, 100, 0.2);
    border-radius: 999px;
    padding: 0.45rem 0.95rem;
    color: var(--text-soft);
    text-decoration: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease,
      background 0.3s ease;
  }

  .picks-filter-link:hover {
    transform: translateY(-2px);
    border-color: rgba(220, 160, 190, 0.28);
    background: rgba(220, 160, 190, 0.08);
    color: var(--text-heading);
  }

  .picks-sections {
    display: grid;
    gap: 3rem;
  }

  .pick-section {
    scroll-margin-top: 6.5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .section-header h2 {
    margin: 0;
    color: var(--text-heading);
    font-family: 'Zen Old Mincho', serif;
    font-size: 1.15rem;
    font-weight: 400;
    letter-spacing: 0.12em;
  }

  .section-icon {
    color: var(--text-muted);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
  }

  .section-header .line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(220, 160, 190, 0.22), transparent);
  }

  .picks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.6rem;
  }

  .pick-card {
    position: relative;
    display: flex;
    height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(220, 160, 190, 0.08);
    background: rgba(255, 255, 255, 0.02);
    text-decoration: none;
    transition:
      transform 0.45s ease,
      border-color 0.45s ease,
      background 0.45s ease,
      box-shadow 0.45s ease;
  }

  .pick-card:hover {
    background: rgba(220, 160, 190, 0.045);
    border-color: rgba(220, 160, 190, 0.18);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(160, 60, 100, 0.08);
  }

  .pick-card-featured {
    border-color: rgba(220, 160, 190, 0.22);
    box-shadow:
      inset 0 0 0 1px rgba(245, 184, 204, 0.06),
      0 18px 54px rgba(160, 60, 100, 0.1);
  }

  .pick-footer {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.9rem;
  }

  .pick-cover {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
  }

  .pick-cover-fallback,
  .pick-cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .pick-cover-fallback {
    background:
      radial-gradient(circle at 22% 20%, rgba(255, 214, 230, 0.28), transparent 24%),
      radial-gradient(circle at 78% 24%, rgba(245, 184, 204, 0.2), transparent 26%),
      linear-gradient(135deg, rgba(212, 120, 154, 0.22), rgba(122, 46, 74, 0.48));
  }

  .pick-cover img {
    object-fit: cover;
    transition: transform 0.45s ease, opacity 0.3s ease;
  }

  .pick-cover[data-error='true'] img {
    opacity: 0;
  }

  .pick-card:hover .pick-cover img {
    transform: scale(1.03);
  }

  .pick-badge {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 1;
    border: 1px solid rgba(245, 184, 204, 0.3);
    background: rgba(10, 6, 8, 0.46);
    backdrop-filter: blur(10px);
    padding: 0.32rem 0.6rem;
    color: var(--text-heading);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pick-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.35rem;
  }

  .pick-body h3 {
    margin: 0 0 0.65rem;
    color: var(--text-heading);
    font-family: 'Zen Old Mincho', serif;
    font-size: 1.08rem;
    font-weight: 400;
    line-height: 1.55;
  }

  .pick-title-main,
  .pick-title-alt {
    display: block;
  }

  .pick-title-alt {
    margin-top: 0.2rem;
    color: var(--text-soft);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .pick-body p {
    margin: 0;
    overflow: hidden;
    color: var(--text-soft);
    line-height: 1.8;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .pick-artist {
    margin: 0;
    margin-bottom: 0.7rem;
    overflow: hidden;
    color: var(--text-soft);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.76rem;
    letter-spacing: 0.04em;
    line-height: 1.7;
    opacity: 0.9;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .pick-description {
    margin: 0;
    overflow: hidden;
    color: var(--text-soft);
    line-height: 1.8;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    transition: -webkit-line-clamp 0.3s ease;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding-top: 0.2rem;
  }

  .tag {
    display: inline-block;
    border: 1px solid rgba(160, 60, 100, 0.2);
    border-radius: 2px;
    padding: 0.2em 0.8em;
    color: var(--sakura-400);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    opacity: 0.72;
  }

  .pick-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .pick-open-link,
  .pick-expand-toggle {
    border: 1px solid rgba(220, 160, 190, 0.18);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.42rem 0.78rem;
    color: var(--text-soft);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-decoration: none;
    transition:
      border-color 0.3s ease,
      background 0.3s ease,
      color 0.3s ease,
      transform 0.3s ease;
  }

  .pick-open-link:hover,
  .pick-expand-toggle:hover {
    border-color: rgba(220, 160, 190, 0.32);
    background: rgba(220, 160, 190, 0.08);
    color: var(--text-heading);
    transform: translateY(-1px);
  }

  .pick-expand-toggle {
    cursor: pointer;
    display: none;
  }

  .pick-open-link {
    display: none;
  }

  .pick-empty {
    border: 1px solid rgba(220, 160, 190, 0.12);
    background:
      radial-gradient(circle at top left, rgba(255, 214, 230, 0.14), transparent 34%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.03), rgba(212, 120, 154, 0.06));
    padding: 1.5rem 1.4rem;
    color: var(--text-soft);
    font-family: 'Noto Sans JP', sans-serif;
    line-height: 1.9;
  }

  @media (hover: hover) and (pointer: fine) {
    .pick-card:hover .pick-description {
      -webkit-line-clamp: 6;
    }
  }

  @media (max-width: 767px) {
    .picks-filter {
      margin-bottom: 2rem;
    }

    .pick-section {
      scroll-margin-top: 5.5rem;
    }

    .section-header {
      gap: 0.75rem;
      margin-bottom: 1.2rem;
    }

    .section-header h2 {
      font-size: 1rem;
      letter-spacing: 0.1em;
    }

    .section-icon {
      display: none;
    }

    .pick-description {
      -webkit-line-clamp: 2;
    }

    .pick-card[data-expanded='true'] .pick-description {
      -webkit-line-clamp: 8;
    }

    .pick-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .pick-open-link,
    .pick-expand-toggle {
      display: block;
      text-align: center;
    }
  }
</style>
